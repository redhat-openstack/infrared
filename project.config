[access]
	inheritFrom = All-Projects
[access "refs/*"]
	owner = group rhosqeauto-stable
	owner = group user/Arx Cruz (arxcruz)
	owner = group user/Luigi Toscano (tosky)
	owner = group user/Oleg Belolipetskii (belolipa)
	owner = group user/Tuvya Korol (tkorol)
	owner = group user/jirimacku
	owner = group user/rhosqeauto (rhosqeauto)
	read = group Anonymous Users
	read = group Registered Users
	push = deny group Registered Users
	pushMerge = deny group Registered Users
	revert = group rhosqeauto-core
	editHashtags = group rhosqeauto-stable
[access "refs/for/refs/*"]
	push = deny group Registered Users
	push = group github/redhat-openstack
	push = group rhosqeauto-contrib
	push = group rhosqeauto-core
	push = group rhosqeauto-stable
	label-Code-Review = -2..+2 group rhosqeauto-stable
	label-Verified = -1..+1 group rhosqeauto-stable
	rebase = group github/redhat-openstack
	rebase = group rhosqeauto-contrib
	rebase = group rhosqeauto-core
	rebase = group rhosqeauto-stable
	editHashtags = group rhosqeauto-stable
[access "refs/heads/*"]
	read = group rhosqeauto-stable
	create = group rhosqeauto-stable
	push = +force group rhosqeauto-stable
	pushMerge = group rhosqeauto-stable
	forgeCommitter = group rhosqeauto-stable
	label-Code-Review = -2..+2 group rhosqeauto-contrib
	label-Code-Review = -2..+2 group rhosqeauto-core
	label-Code-Review = -2..+2 group rhosqeauto-stable
	label-Code-Review = -1..+1 group github/redhat-openstack
	label-Verified = -1..+1 group rhosqeauto-core
	label-Verified = -1..+1 group rhosqeauto-stable
	label-Verified = -1..+1 group user/rhosqeauto (rhosqeauto)
	rebase = group rhosqeauto-contrib
	rebase = group rhosqeauto-core
	rebase = group rhosqeauto-stable
	removeReviewer = group rhosqeauto-core
	removeReviewer = group rhosqeauto-stable
	submit = deny group Registered Users
	submit = group rhosqeauto-stable
[access "refs/tags/*"]
	push = +force group rhosqeauto-stable
	create = group rhosqeauto-stable
	createTag = group rhosqeauto-stable
	createSignedTag = group rhosqeauto-stable
[access "refs/heads/infrared_v1"]
	push = deny group Registered Users
	push = group rhosqeauto-stable
[project]
	description = " "
[plugin "zuul-results-summary"]
	enabled = false
[plugin "uploadvalidator"]
	blockedContentTypeWhitelist = false
	maxPathLength = 0
	rejectDuplicatePathnamesLocale = en
	rejectSubmodule = false
	rejectSymlink = false
	rejectWindowsLineEndings = false
